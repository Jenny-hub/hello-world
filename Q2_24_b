import threading
import time
import math

max_num = 10000
n_thr = 4


#  Returns True iff n is a special number
def is_special(n):
    nn = list(map(int, str(n)))
    return sum(nn) % len(nn) == 0



#  Returns the number of special numbers in the range rng = (low, high)
def rspecials(rng: tuple, results_list, idx):
    num = 0
    for n in range(rng[0], rng[1]):
        if is_special(n):
            num += 1
    results_list[idx] = num  # store result in shared list


#  Breaks the range [0, rng) into num equally sized subranges
def calc_ranges(rmax, num):
    ranges = []
    idx, rsize = 0, rmax // num
    for _ in range(num - 1):
        ranges.append((idx, idx + rsize))
        idx += rsize
    ranges.append((idx, rmax))
    return ranges


ranges = calc_ranges(max_num, n_thr)

# Shared list to store results from threads
results = [0] * n_thr
threads = []

start = time.perf_counter()

# Create and start threads
for i in range(n_thr):
    t = threading.Thread(target=rspecials, args=(ranges[i], results, i))
    threads.append(t)
    t.start()

# Wait for all threads to finish
for t in threads:
    t.join()

total_specials = sum(results) # Sum counts from all threads
end = time.perf_counter()

print(f'Number of special numbers up to {max_num}: {total_specials} ({round(end - start, 2)} second(s))')
print(f'Time taken: {round(end - start, 2)} seconds')
